# ============================================================
# Royal LePage AI Platform — Root .env.example
# Copy to .env and fill in all values before deploying.
# ============================================================

# ── GoHighLevel ─────────────────────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=

# Set after running: cd ghl-setup && npm run setup
GHL_PIPELINE_ID=
GHL_CALENDAR_ID=
GHL_STAGE_NEW_LEAD=
GHL_STAGE_ATTEMPTED=
GHL_STAGE_CONTACTED=
GHL_STAGE_QUALIFIED=
GHL_STAGE_APPOINTMENT_SET=
GHL_STAGE_HANDED_OFF=
GHL_STAGE_NURTURE=
GHL_CAMPAIGN_DRIP_7DAY=
GHL_CAMPAIGN_REACTIVATION=

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ── IDX / MLS ────────────────────────────────────────────────
# Canada: set IDX_PROVIDER=crea_ddf and apply at crea.ca/data-feed
# US:     set IDX_PROVIDER=simplyrets and get creds at simplyrets.com
IDX_PROVIDER=crea_ddf
IDX_API_KEY=
IDX_API_SECRET=
IDX_FEED_URL=

# ── ElevenLabs (optional — voice AI) ─────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_FROM_PHONE=

# ── Orchestrator ─────────────────────────────────────────────
PORT=3000
ORCHESTRATOR_URL=https://your-orchestrator.railway.app
WEBHOOK_SECRET=change-me-to-a-random-32-char-string
# Rate limiting (defaults: 5 concurrent agents, 1000ms per-contact cooldown)
AGENT_CONCURRENCY=5
AGENT_COOLDOWN_MS=1000

# ── Queue (BullMQ) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
QUEUE_PORT=3001
QUEUE_SECRET=change-me-to-a-random-32-char-string
WORKER_CONCURRENCY=5
# Secret the queue worker uses when forwarding jobs to the orchestrator
ORCHESTRATOR_WEBHOOK_SECRET=change-me-to-a-random-32-char-string

# ── Monitoring ────────────────────────────────────────────────
MONITORING_PORT=3002
MONITORING_SECRET=change-me-to-a-random-32-char-string

# ── MCP servers (used when running locally) ──────────────────
# All MCP servers read GHL_API_KEY, GHL_LOCATION_ID, ANTHROPIC_API_KEY above.
# Showings:
GHL_CALENDAR_ID_SHOWINGS=
SHOWINGTIME_API_KEY=

# ── Language ──────────────────────────────────────────────────
# en = English only | fr = French only | bilingual = auto-detect (recommended for Canada)
AGENT_LANGUAGE=bilingual
